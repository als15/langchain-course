# LLM Provider: "ollama" for local, "openai" for cloud/Railway
LLM_PROVIDER=ollama

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Tavily (web search for research & leads)
TAVILY_API_KEY=

# LangSmith (optional, observability)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=Capa & Co

# Meta / Instagram Graph API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_AUTHORIZED_USERS=

# Stability AI (image generation)
STABILITY_API_KEY=

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database (optional, default: data/capaco.db)
# DATABASE_PATH=/app/data/capaco.db
