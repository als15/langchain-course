# Credentials for your brand
# Copy this to .env and fill in your values

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Instagram / Meta API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_AUTHORIZED_USERS=

# Image Generation (fal.ai)
FAL_KEY=

# Image Hosting (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Search (Tavily)
TAVILY_API_KEY=

# Database (leave empty for SQLite default)
DATABASE_URL=
DATABASE_PATH=data/brand.db

# Dashboard
DASHBOARD_SECRET=

# Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=
